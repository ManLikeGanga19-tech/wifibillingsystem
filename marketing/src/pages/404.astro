---
import Base from '../layouts/Base.astro';
---

<Base title="Not found — WIFI.OS" description="That page does not exist.">
  <section class="mx-auto max-w-3xl px-4 py-24 text-center sm:px-6">
    <p class="font-mono text-6xl font-black text-money">404</p>
    <h1 class="mt-4 font-serif text-3xl font-bold">That page is not here.</h1>
    <p class="mt-3 text-sm text-ink/70">It may have moved, or it may never have existed.</p>
    <div class="mt-7 flex flex-wrap justify-center gap-3">
      <a
        href="/"
        class="border border-ink bg-card px-5 py-3 font-mono text-xs font-bold uppercase transition hover:bg-hover"
      >
        Back home
      </a>
      <a
        href="/signup"
        class="border border-money bg-money px-5 py-3 font-mono text-xs font-bold uppercase text-white transition hover:opacity-85"
      >
        Get started
      </a>
    </div>
  </section>
</Base>
