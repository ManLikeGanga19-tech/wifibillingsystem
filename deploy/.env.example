# Copy to deploy/.env on the server and fill in. NEVER commit the real file.
#
# THE RULE FOR THIS SYSTEM: zero keys in source. Every secret arrives as an environment
# variable, and config/settings/prod.py REFUSES TO BOOT if the critical ones are absent
# — a misconfigured deploy should crash in thirty seconds, not quietly downgrade itself
# and be discovered during an incident.
#
# Generate the two crypto values with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"                  # DJANGO_SECRET_KEY
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"  # FIELD_ENCRYPTION_KEY
#
# LOSING FIELD_ENCRYPTION_KEY MEANS LOSING EVERY ROUTER PASSWORD AND EVERY TOTP SEED.
# It cannot be regenerated. Keep a copy somewhere that is not this server.

# ---- identity of this deployment ----------------------------------------------------
# staging | production. Only affects what you name things — the topology is identical,
# which is the point: staging must be able to lie to you as little as possible.
ENVIRONMENT=staging

DJANGO_SECRET_KEY=
FIELD_ENCRYPTION_KEY=

# Every hostname Django will answer on. A request with any other Host is rejected — this
# is what stops Host-header poisoning, and it is why the wildcard is explicit.
DJANGO_ALLOWED_HOSTS=.wifios.co.ke,wifios.co.ke

# Origins allowed to send cookie-authenticated writes. Cookie auth means CSRF is a live
# threat, so this list is a security control, not configuration noise.
CSRF_TRUSTED_ORIGINS=https://wifios.co.ke,https://*.wifios.co.ke

# One login across acme.wifios.co.ke and admin.wifios.co.ke.
COOKIE_DOMAIN=.wifios.co.ke

# ---- database + cache ---------------------------------------------------------------
POSTGRES_USER=wifios
POSTGRES_PASSWORD=
POSTGRES_DB=wifios
DATABASE_URL=postgres://wifios:CHANGEME@db:5432/wifios

REDIS_PASSWORD=
REDIS_URL=redis://:CHANGEME@redis:6379/0

# ---- TLS ----------------------------------------------------------------------------
# Caddy gets *.wifios.co.ke from Let's Encrypt via a DNS challenge (a wildcard cannot be
# issued over HTTP-01). The token needs DNS:Edit on this zone ONLY — not account access.
ACME_EMAIL=ops@wifios.co.ke
CLOUDFLARE_API_TOKEN=

# ---- M-Pesa (Daraja) ----------------------------------------------------------------
# Sandbox on staging. Production credentials go ONLY in the production env file, and the
# two must never share a database — a sandbox callback landing in the production ledger
# is a fake payment against a real ISP's balance.
DARAJA_CONSUMER_KEY=
DARAJA_CONSUMER_SECRET=
DARAJA_SHORTCODE=
DARAJA_PASSKEY=

# The callback URL Safaricom posts to. It carries a shared token so anybody who guesses
# the URL still cannot forge a payment.
DARAJA_CALLBACK_BASE_URL=https://api.wifios.co.ke
DARAJA_CALLBACK_TOKEN=

# ---- email --------------------------------------------------------------------------
# STAGING: point this at mailpit. A staging box wired to a real SMTP provider will
# cheerfully email real ISPs invoices and suspension notices generated from test data.
#   EMAIL_HOST=mailpit
#   EMAIL_PORT=1025
#   EMAIL_USE_TLS=0
#
# PRODUCTION: a real provider.
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=mailpit
EMAIL_PORT=1025
EMAIL_USE_TLS=0
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=WIFI.OS <noreply@wifios.co.ke>

# ---- SMS ----------------------------------------------------------------------------
NOTIFICATIONS_PROVIDER=dummy
AT_API_KEY=

# ---- sizing (one small VPS) ---------------------------------------------------------
GUNICORN_WORKERS=3
CELERY_CONCURRENCY=4
BACKUP_KEEP_DAYS=14
