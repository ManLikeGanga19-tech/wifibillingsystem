---
const year = new Date().getFullYear();

const columns = [
  {
    title: 'Product',
    links: [
      { href: '/#product', label: 'Hotspot billing' },
      { href: '/#product', label: 'PPPoE billing' },
      { href: '/#product', label: 'MikroTik control' },
      { href: '/pricing', label: 'Pricing' },
    ],
  },
  {
    title: 'Company',
    links: [
      { href: '/#how', label: 'How it works' },
      { href: '/#faq', label: 'FAQ' },
      { href: 'mailto:hello@wifios.co.ke', label: 'hello@wifios.co.ke' },
      { href: 'tel:+254700000000', label: '+254 700 000 000' },
    ],
  },
  {
    title: 'Legal',
    links: [
      { href: '/terms', label: 'Terms of Service' },
      { href: '/privacy', label: 'Privacy Policy' },
    ],
  },
];
---

<footer class="border-t border-ink bg-card">
  <div class="mx-auto grid max-w-6xl gap-8 px-4 py-10 sm:px-6 md:grid-cols-4">
    <div>
      <p class="flex items-center gap-2 font-mono text-sm font-black uppercase">
        <span class="grid h-6 w-6 place-items-center border border-ink bg-ink text-[10px] text-paper">W</span>
        WIFI<span class="text-money">.OS</span>
      </p>
      <p class="mt-3 max-w-xs text-xs leading-relaxed text-ink/70">
        Billing, provisioning and payments for Kenyan internet service providers. Built by
        people who run a WISP.
      </p>
      <p class="mt-3 font-mono text-[10px] uppercase tracking-wide text-ink/50">
        A Danamo Tech Ltd product · Nairobi, Kenya
      </p>
    </div>

    {
      columns.map((col) => (
        <div>
          <p class="font-mono text-[10px] font-bold uppercase tracking-widest text-ink/50">
            {col.title}
          </p>
          <ul class="mt-3 space-y-2">
            {col.links.map((l) => (
              <li>
                <a href={l.href} class="text-xs text-ink/80 underline-offset-4 hover:underline">
                  {l.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))
    }
  </div>

  <div class="border-t border-ink/15">
    <div
      class="mx-auto flex max-w-6xl flex-col gap-2 px-4 py-4 font-mono text-[10px] uppercase tracking-wide text-ink/50 sm:flex-row sm:items-center sm:justify-between sm:px-6"
    >
      <p>© {year} Danamo Tech Ltd. All rights reserved.</p>
      <p>M-Pesa is a trademark of Safaricom PLC. We are not affiliated with Safaricom.</p>
    </div>
  </div>
</footer>
