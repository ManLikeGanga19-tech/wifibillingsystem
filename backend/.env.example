# Copy to .env (or export in your shell) — Docker Compose passes these through.

# Django
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DATABASE_URL=postgres://wifi:wifi@db:5432/wifi
REDIS_URL=redis://redis:6379/0

# Secrets encryption (generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
FIELD_ENCRYPTION_KEY=

# Safaricom Daraja — sandbox creds from https://developer.safaricom.co.ke
DARAJA_BASE_URL=https://sandbox.safaricom.co.ke
DARAJA_CONSUMER_KEY=
DARAJA_CONSUMER_SECRET=
DARAJA_SHORTCODE=174379
DARAJA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919
# Public HTTPS URL Safaricom can reach (Cloudflare Tunnel / ngrok in dev)
DARAJA_CALLBACK_BASE_URL=
DARAJA_CALLBACK_TOKEN=pick-a-long-random-string

# Africa's Talking SMS (username 'sandbox' targets their sandbox)
AT_USERNAME=sandbox
AT_API_KEY=
AT_SENDER_ID=

# WhatsApp Business Cloud API (Meta)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Set to 'dummy' to log messages instead of sending (dev/tests)
NOTIFICATIONS_PROVIDER=dummy
